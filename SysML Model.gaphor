<reflist>
<ref refid="0d32fcd3-83ff-11f1-bcda-4c5f70d96867"/>
</reflist>
</presentation>
<targetDirectedRelationshipPropertyPath_>
<reflist>
<ref refid="05660346-85bd-11f1-a06d-4c5f70d96864"/>
</reflist>
</targetDirectedRelationshipPropertyPath_>
<text>
<val>Expose a replaceable scent attractant to the surronding air</val>
</text>
</SysML:Requirement>
<SysML:Requirement id="a35ad03e-83fe-11f1-8ce1-4c5f70d96867">
<externalId>
<val>SR-04</val>
</externalId>
<name>
<val>House Integration</val>
</name>
<owningPackage>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</owningPackage>
<package>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</package>
<presentation>
<reflist>
<ref refid="a35d110e-83fe-11f1-8fe1-4c5f70d96867"/>
</reflist>
</presentation>
<text>
<val>Use a decorative pitcher plant inspired form</val>
</text>
</SysML:Requirement>
<SysML:Requirement id="50cfba78-83fe-11f1-86e4-4c5f70d96867">
<externalId>
<val>SR-03</val>
</externalId>
<name>
<val>Hygienic Maintenance</val>
</name>
<owningPackage>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</owningPackage>
<package>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</package>
<presentation>
<reflist>
<ref refid="50d0221e-83fe-11f1-9fb8-4c5f70d96867"/>
</reflist>
</presentation>
<text>
<val>Allow disposal and cleaning with minimal direct contact</val>
</text>
</SysML:Requirement>
<SysML:Requirement id="980f9338-83fd-11f1-b403-4c5f70d96867">
<externalId>
<val>SR-02</val>
</externalId>
<name>
<val>Reduced Chemical Reliance</val>
</name>
<owningPackage>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</owningPackage>
<package>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</package>
<presentation>
<reflist>
<ref refid="9810740d-83fd-11f1-8998-4c5f70d96867"/>
</reflist>
</presentation>
<text>
<val>Reduce routine reliance on pesticidie sprays</val>
</text>
</SysML:Requirement>
<SysML:Requirement id="d1c969f1-83fc-11f1-937b-4c5f70d96867">
<externalId>
<val>SR-00</val>
</externalId>
<name>
<val>Home Friendly Pest Management</val>
</name>
