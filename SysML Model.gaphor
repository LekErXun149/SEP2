<SysML:Requirement id="1f2cf368-8404-11f1-b5d9-4c5f70d96867">
<externalId>
<val>TR-05</val>
</externalId>
<name>
<val>3D-Printable Housing</val>
</name>
<owningPackage>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</owningPackage>
<package>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</package>
<presentation>
<reflist>
<ref refid="1f2d63b2-8404-11f1-9f88-4c5f70d96867"/>
</reflist>
</presentation>
<targetDirectedRelationshipPropertyPath_>
<reflist>
<ref refid="e0b13ecd-8413-11f1-addc-4c5f70d96867"/>
</reflist>
</targetDirectedRelationshipPropertyPath_>
<text>
<val>The system shall fit the 12V Fan, Rechargeable 12V Battery, Power Switch, Attractant Reservoir and Capture Chamber within the revised CAD housing.</val>
</text>
</SysML:Requirement>
<SysML:Requirement id="8a3d23d7-8403-11f1-a752-4c5f70d96867">
<externalId>
<val>TR-04</val>
</externalId>
<name>
<val>Removable Capture Chamber</val>
</name>
<owningPackage>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</owningPackage>
<package>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</package>
<presentation>
<reflist>
<ref refid="8a3d98a7-8403-11f1-b296-4c5f70d96867"/>
</reflist>
</presentation>
<targetDirectedRelationshipPropertyPath_>
<reflist>
<ref refid="be9563e7-8413-11f1-90b8-4c5f70d96867"/>
</reflist>
</targetDirectedRelationshipPropertyPath_>
<text>
<val>Provide a removeable, cleanable chamber with escape resitant internal surface</val>
</text>
</SysML:Requirement>
<SysML:Requirement id="891cd81b-8403-11f1-b0cb-4c5f70d96867">
<externalId>
<val>TR-03</val>
</externalId>
<name>
<val>Attractant Reservoir</val>
</name>
<owningPackage>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</owningPackage>
<package>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</package>
<presentation>
<reflist>
<ref refid="891d6f8f-8403-11f1-8e67-4c5f70d96867"/>
</reflist>
</presentation>
<targetDirectedRelationshipPropertyPath_>
<reflist>
<ref refid="68737c0c-8413-11f1-b4de-4c5f70d96867"/>
<ref refid="fe4f0c55-8413-11f1-b86b-4c5f70d96867"/>
</reflist>
</targetDirectedRelationshipPropertyPath_>
<text>
<val>Use a refillable or replaceable attractant holder</val>
</text>
</SysML:Requirement>
<SysML:Requirement id="42454efa-8403-11f1-acb7-4c5f70d96867">
<externalId>
<val>TR-02</val>
</externalId>
<name>
<val>Fan Performance</val>
</name>
<owningPackage>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</owningPackage>
<package>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</package>
<presentation>
<reflist>
<ref refid="4245c3e3-8403-11f1-be42-4c5f70d96867"/>
</reflist>
</presentation>
<targetDirectedRelationshipPropertyPath_>
<reflist>
<ref refid="97dba530-8413-11f1-902e-4c5f70d96867"/>
</reflist>
</targetDirectedRelationshipPropertyPath_>
<text>
<val>The selected fan shall provide stable airflow for the prototype</val>
</text>
</SysML:Requirement>
<SysML:Requirement id="6e6ac5e3-8402-11f1-b019-4c5f70d96867">
<externalId>
<val>TR-01</val>
</externalId>
<name>
<val>Rechargeable 12V Battery Power</val>
</name>
<owningPackage>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</owningPackage>
<package>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</package>
<presentation>
<reflist>
<ref refid="6e6b5f88-8402-11f1-a564-4c5f70d96867"/>
</reflist>
</presentation>
<targetDirectedRelationshipPropertyPath_>
<reflist>
<ref refid="7cf848b2-8413-11f1-a6b5-4c5f70d96867"/>
</reflist>
</targetDirectedRelationshipPropertyPath_>
<text>
<val>The system shall use a rechargeable 12V Battery to supply power to the 12V Fan.</val>
</text>
</SysML:Requirement>
<SysML:Requirement id="92f4ae65-8401-11f1-9f7a-4c5f70d96867">
<externalId>
<val>LR-05</val>
</externalId>
<name>
<val>Support Maintenance</val>
</name>
<owningPackage>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</owningPackage>
<package>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</package>
<presentation>
<reflist>
<ref refid="92f5085f-8401-11f1-8890-4c5f70d96867"/>
</reflist>
</presentation>
<targetDirectedRelationshipPropertyPath_>
<reflist>
<ref refid="3deaed4b-8411-11f1-9398-4c5f70d96867"/>
</reflist>
</targetDirectedRelationshipPropertyPath_>
<text>
<val>Provide access to refill attractant and remove, clean and reinstall the chamber</val>
</text>
</SysML:Requirement>
<SysML:Requirement id="315de94e-8401-11f1-a563-4c5f70d96867">
<externalId>
<val>LR-04</val>
</externalId>
<name>
<val>Contain Pest</val>
</name>
<owningPackage>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</owningPackage>
<package>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</package>
<presentation>
<reflist>
<ref refid="315e5e92-8401-11f1-bba6-4c5f70d96867"/>
</reflist>
</presentation>
<targetDirectedRelationshipPropertyPath_>
<reflist>
<ref refid="2259a9f3-85bd-11f1-acb2-4c5f70d96864"/>
</reflist>
</targetDirectedRelationshipPropertyPath_>
<text>
<val>Retain captured pests and discourage escape</val>
</text>
</SysML:Requirement>
<SysML:Requirement id="6ca08459-8400-11f1-88a5-4c5f70d96867">
<externalId>
<val>LR-03</val>
</externalId>
<name>
<val>Guide Pest</val>
</name>
<owningPackage>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</owningPackage>
<package>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</package>
<presentation>
<reflist>
<ref refid="6ca0ecee-8400-11f1-a933-4c5f70d96867"/>
</reflist>
</presentation>
<targetDirectedRelationshipPropertyPath_>
<reflist>
<ref refid="0789c807-85bd-11f1-b64c-4c5f70d96864"/>
</reflist>
</targetDirectedRelationshipPropertyPath_>
<text>
<val>Use internal geometry to route an entering pest to the bottom chamber</val>
</text>
</SysML:Requirement>
<SysML:Requirement id="bf7dc4ec-83ff-11f1-9c4c-4c5f70d96867">
<externalId>
<val>LR-02</val>
</externalId>
<name>
<val>Generate and Direct Airflow</val>
</name>
<owningPackage>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</owningPackage>
<package>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</package>
<presentation>
<reflist>
<ref refid="bf7e2dc8-83ff-11f1-8e9a-4c5f70d96867"/>
</reflist>
</presentation>
<targetDirectedRelationshipPropertyPath_>
<reflist>
<ref refid="08fe242e-85bd-11f1-a43a-4c5f70d96864"/>
</reflist>
</targetDirectedRelationshipPropertyPath_>
<text>
<val>Generate airflow to distribute scent and guide entering pests downward</val>
</text>
</SysML:Requirement>
<SysML:Requirement id="0d324c8f-83ff-11f1-b3d4-4c5f70d96867">
<externalId>
<val>LR-01</val>
</externalId>
<name>
<val>Attract Pest</val>
</name>
<owningPackage>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</owningPackage>
<package>
<ref refid="58d6c2e8-66f8-11ec-b4c8-0456e5e540ed"/>
</package>
