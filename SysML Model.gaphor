<model>
<Core:StyleSheet id="58d6989a-66f8-11ec-b4c8-0456e5e540ed">
<styleSheet>
<val>diagram {
 /* line-style: sloppy 0.3; */
}

controlflow {
  dash-style: 0;
}

/* UC subject styling only */
diagram[name="Operation and Maintenance Use Cases"]
block[name="PitcherGuard"] stereotypes,
diagram[name="Operation and Maintenance Use Cases"]
block[name="PitcherGuard"] from {
  opacity: 0;
  font-size: 0;
  padding: 0;
  min-height: 0;
}

/* Move PitcherGuard name to the top */
diagram[name="Operation and Maintenance Use Cases"]
block[name="PitcherGuard"] {
  justify-content: start;
}

diagram[name="Operation and Maintenance Use Cases"]
block[name="PitcherGuard"] &gt; compartment:first-child {
  justify-content: start;
}

diagram[name="Operation and Maintenance Use Cases"]
block[name="PitcherGuard"] name {
  vertical-align: top;
  text-align: center;
  font-size: 16;
  font-weight: bold;
  padding: 8 4 4 4;
}

/* Hide namespace text only in the Package Diagram */
diagram[name="Model Package Organization"] package &gt; from {
  opacity: 0;
  font-size: 0;
  min-height: 0;
  padding: 0;
}</val>
</styleSheet>
</Core:StyleSheet>
