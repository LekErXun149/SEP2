<SysML:Requirement id="32a1db5b-7ed7-11f1-a657-d6ae1adfc68a">
<externalId>
<val>01</val>
</externalId>
<name>
<val>Non pesticide use</val>
</name>
<owningPackage>
<ref refid="012edaba-70f5-11ec-aabc-f47b099bf663"/>
</owningPackage>
<package>
<ref refid="012edaba-70f5-11ec-aabc-f47b099bf663"/>
</package>
<presentation>
<reflist>
<ref refid="32a21877-7ed7-11f1-a814-d6ae1adfc68a"/>
</reflist>
</presentation>
<text>
